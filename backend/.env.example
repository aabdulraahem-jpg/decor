NODE_ENV=development
PORT=4000

# Database (MySQL on HestiaCP) — استبدل PASSWORD_HERE بالقيمة الفعلية في .env
DATABASE_URL="mysql://sufuf_Notouch:PASSWORD_HERE@localhost:3306/sufuf_sufuf_db"

# JWT
JWT_SECRET=change_me_strong_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.sufuf.pro/auth/google/callback

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=https://api.sufuf.pro/auth/apple/callback

# CORS
CORS_ORIGINS=https://sufuf.pro,https://app.sufuf.pro,https://admin.sufuf.pro

# OpenAI (مدارة عبر DB ApiSetting وقت التشغيل، لكن يستخدم كقيمة احتياطية)
OPENAI_API_KEY=

# Cloudflare Turnstile (anti-bot CAPTCHA on /auth/login + /auth/register)
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
# Leave SECRET empty in dev to skip captcha verification.
TURNSTILE_SECRET_KEY=

# WhatsApp Cloud API (Meta) — FREE up to 1,000 service conversations/month.
# Apply at https://developers.facebook.com → Apps → WhatsApp.
# Until set, OTP codes are logged to pm2 for manual delivery.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=verify_otp

# SMTP for email OTP fallback (Gmail App Password / Brevo / SendGrid free)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=صفوف رايقة <noreply@sufuf.pro>

# Amazon Payment Services (APS / PayFort)
# يمكن ضبطها هنا كاحتياط أو عبر لوحة الأدمن (Admin > إعدادات الدفع)
APS_MERCHANT_ID=
APS_ACCESS_CODE=
APS_SHA_REQUEST=      # SHA Request Phrase من لوحة APS
APS_SHA_RESPONSE=     # SHA Response Phrase من لوحة APS
APS_BASE_URL=https://checkout.paymentservices.amazon.com/FortAPI/paymentPage
# Sandbox: https://sbcheckout.paymentservices.amazon.com/FortAPI/paymentPage
